# ── BookStack-Instanz ────────────────────────────────────────────────────────
BOOKSTACK_URL=http://<host>:80
# Alternativ-Name (Fallback, falls BOOKSTACK_URL nicht gesetzt):
# API_HOST=http://<host>:80

# Datenbankpfad (Standard: ./schreibwerkstatt.db; bei Docker via docker-compose gesetzt)
# DB_PATH=/app/data/schreibwerkstatt.db

# Port des lokalen Dev-Servers (Standard: 3737)
# PORT=3737

# ── Google OAuth2 Login ──────────────────────────────────────────────────────
# Google Cloud Console → APIs & Dienste → Anmeldedaten → OAuth 2.0-Client-IDs
# Autorisierte Weiterleitungs-URI: https://<deine-domain>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Öffentliche URL der App (für OAuth2-Callback, ohne Slash am Ende)
# Standard bei Entwicklung: http://localhost:3737
APP_URL=https://<deine-domain>

# Zufälliger Schlüssel für Session-Signierung und Token-Verschlüsselung (min. 32 Zeichen)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Whitelist: nur diese Google-Konten dürfen sich einloggen (kommasepariert).
# WICHTIG: Leer lassen = ALLE Google-Konten haben Zugriff!
ALLOWED_EMAILS=alice@example.com,bob@example.com

# ── KI-Provider ──────────────────────────────────────────────────────────────
# Welcher Provider verwendet wird: 'claude' (Standard), 'ollama' oder 'llama'
# API_PROVIDER=claude

# ── Claude (Anthropic) ──────────────────────────────────────────────────────
# Nur nötig wenn API_PROVIDER=claude (oder nicht gesetzt)
ANTHROPIC_API_KEY=sk-ant-...

# Claude-Modell (Standard: claude-sonnet-4-6)
# Optionen: claude-opus-4-6, claude-haiku-4-5-20251001
# MODEL_NAME=claude-sonnet-4-6

# ── Modell-Grenzen (provider-übergreifend) ──────────────────────────────────
# Zwei getrennte Werte – oft verwechselt, deshalb ausdrücklich:
#
# MODEL_TOKEN   = Max. OUTPUT-Tokens pro KI-Aufruf (Standard: 64000).
#                 Wird als max_tokens / num_predict an den Provider gereicht.
#                 Deckt alle Jobs (Lektorat, Review, Komplett-Analyse, Chat etc.)
#                 und deckelt Job-spezifische Overrides per Math.min.
#
# MODEL_CONTEXT = Gesamtes KONTEXTFENSTER des Modells, Input + Output (Standard: 200000).
#                 - Claude Sonnet/Opus 4.x: providerseitig fix 200000
#                 - Ollama / llama.cpp: auf die native Kontextgrösse des geladenen
#                   Modells setzen – Mistral-Small3.2 / Gemma3-12B / Llama-3.1: 131072,
#                   Phi-3-mini: 131072, ältere Llama-2-Modelle: 4096, Mistral-7B v0.1: 32768.
#                 Wichtig: zu hoher Wert → Input wird vom Provider still gekürzt
#                 (Ollama) oder mit "prompt too long" abgelehnt (Claude).
#
# Daraus leitet der Server automatisch ab:
#   INPUT_BUDGET = MODEL_CONTEXT − MODEL_TOKEN − 2000 (Sicherheitspuffer)
# und dimensioniert davon: SINGLE_PASS_LIMIT / PER_CHUNK_LIMIT (Komplett-Analyse),
# BOOK_CHAT_TOKEN_BUDGET-Default, Buch-Chat-Tool-Result-Caps, Classic-Chat-Textbudget.
# Beim Server-Start wird das effektive Budget geloggt.
#
# MODEL_TOKEN=64000
# MODEL_CONTEXT=200000

# ── Ollama (lokal) ───────────────────────────────────────────────────────────
# Nur nötig wenn API_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_TEMPERATURE=0.2

# ── Llama.cpp / vLLM (OpenAI-kompatibel) ───────────────────────────────────
# Nur nötig wenn API_PROVIDER=llama
# LLAMA_HOST=http://localhost:8080
# LLAMA_MODEL=llama3.2
# LLAMA_TEMPERATURE=0.1

# ── Chat-spezifische Temperatur (nur Ollama/Llama) ──────────────────────────
# Übersteuert OLLAMA_TEMPERATURE/LLAMA_TEMPERATURE AUSSCHLIESSLICH für
# Seiten-Chat (/chat/send) und Buch-Chat (/jobs/book-chat). Andere Jobs
# (Review, Lektorat, Komplett-Analyse, Figuren) bleiben auf ihrer
# Provider-Temperatur, weil sie deterministische JSON-Antworten brauchen.
#
# Hintergrund: kleine lokale Modelle unter JSON-Schema-Zwang neigen dazu,
# Antworten früh zu beenden ("Hier sind die Gründe:" → Ende). Eine leicht
# höhere Temperatur (0.3–0.5) bricht diesen "Abschluss"-Bias auf, ohne die
# Antwortqualität zu gefährden. Nicht gesetzt = bisheriges Verhalten.
# Für Claude (API_PROVIDER=claude) wird dieser Wert ignoriert.
# CHAT_TEMPERATURE=0.4

# ── Job-Queue ────────────────────────────────────────────────────────────────
# Maximale Anzahl gleichzeitig laufender KI-Jobs (über alle User, Standard: 2).
# Bei einem einzelnen Ollama-Modell empfiehlt sich 1, um konkurrierende Anfragen
# zu vermeiden und Rate-Limits nicht zu überlasten.
# MAX_CONCURRENT_JOBS=1

# ── Buch-Chat (Agentic Tool-Use) ─────────────────────────────────────────────
# Der Buch-Chat ruft bei API_PROVIDER=claude Werkzeuge auf (count_pronouns,
# search_passages, get_figure_mentions, get_pages etc.), statt alle Seiten
# vorab in den Kontext zu laden. Voraussetzung: Buchstatistik-Sync ist gelaufen
# (täglich 02:00 Cron oder manuell via POST /sync/all).
#
# Welcher Pfad benutzt wird:
#   'auto'    – Agent bei claude, klassischer Keyword-Scoring-Pfad bei ollama/llama (Standard)
#   'agent'   – Agent erzwingen (nur mit API_PROVIDER=claude sinnvoll)
#   'classic' – immer den klassischen Pfad verwenden (z.B. für Debugging oder Rollback)
# BOOK_CHAT_MODE=auto

# Maximale Anzahl Tool-Use-Iterationen pro Buch-Chat-Antwort (Standard: 6).
# Niedriger = schnellere Antworten, aber evtl. unvollständig. Höher = mehr Werkzeug-Calls pro Anfrage.
# BOOK_CHAT_MAX_TOOL_ITER=6

# Per-Iteration-Limit für Input-Tokens (Context-Window-Schutz, nicht kumulativ).
# Standard = Input-Budget (MODEL_CONTEXT − MODEL_TOKEN − 2000). Explizit setzen nur
# nötig, wenn du das Budget enger ziehen willst als das verfügbare Kontextfenster.
# BOOK_CHAT_TOKEN_BUDGET=

# ── Lokale Entwicklung ──────────────────────────────────────────────────────
# LOCAL_DEV_MODE=true überspringt Google OAuth komplett und legt automatisch
# eine Dev-Session an (dev@local). NIEMALS in Produktion setzen!
# LOCAL_DEV_MODE=true

# BookStack API-Token direkt setzen (nur nötig wenn LOCAL_DEV_MODE=true,
# erspart das manuelle Token-Setup im Browser)
# TOKEN_ID=<token-id>
# TOKEN_KENNWORT=<token-secret>

# ── Logging ─────────────────────────────────────────────────────────────────
# Winston-Log-Level (Standard: info). Optionen: error, warn, info, debug.
# LOG_LEVEL=info

# ── Zeitzone ────────────────────────────────────────────────────────────────
# Globale Timezone für Date/Intl + Cron + Tagesaggregate (Heatmap, page_stats).
# Auf UTC-LXC ohne TZ driften Tagesgrenzen → Heute-Ring zeigt falschen Tag.
# Standard: Europe/Zurich.
# TZ=Europe/Zurich

# ── Cron / Buchstatistik-Sync ────────────────────────────────────────────────
# Override für node-cron-Schedules. Default: TZ.
# CRON_TIMEZONE=Europe/Zurich

# Schwellwert (Tage) für "stale" page_stats — Cron synct nur Bücher, deren
# letzter Sync älter ist. Standard: 7.
# STALE_DAYS=7

# ── KI-Aufruf-Tuning (lib/ai.js) ─────────────────────────────────────────────
# Heuristik für Token-Schätzung aus Zeichenanzahl. Default je Provider:
# claude=3, ollama/llama=1.5. Übersteuern nur wenn Schätzung systematisch
# daneben liegt (z.B. extrem deutsch-/code-lastige Texte).
# CHARS_PER_TOKEN=3

# Max. Retry-Versuche bei Claude-Fehlern (429/5xx/Overloaded). Standard: 3.
# CLAUDE_RETRY_MAX=3

# Timeout pro Claude-Request in Millisekunden. Standard: 600000 (10 Minuten).
# Lange Timeouts sind nötig für grosse Komplettanalyse-Calls mit vielen Tokens.
# CLAUDE_TIMEOUT_MS=600000

# ── Job-Parallelität (Feintuning) ────────────────────────────────────────────
# Parallelität der Phase-1-Kapitelextraktion in der Komplettanalyse, wenn
# API_PROVIDER=claude. Standard: 4. Bei lokalen Providern (ollama/llama) wird
# ohnehin via Mutex auf 1 serialisiert. Höhere Werte → schnellere Pipeline,
# aber höheres Risiko von Anthropic-429-Rate-Limits.
# CLAUDE_PHASE1_CONCURRENCY=4

# Parallelität für Batch-Lektorat (mehrere Seiten in einem Job). Standard: 4
# bei Claude, fest 1 bei lokalen Providern. Analog zu CLAUDE_PHASE1_CONCURRENCY.
# LEKTORAT_BATCH_CONCURRENCY=4

# ── PDF/A-Validierung (veraPDF) ──────────────────────────────────────────────
# Pfad zur veraPDF-CLI-Binary. Standard: 'verapdf' (muss im PATH sein).
# Fehlt das Binary → Validation wird übersprungen, PDF wird trotzdem geliefert.
# VERAPDF_BIN=verapdf

# PDF/A-Flavour für Validation. Standard: 2b (passt zum eigenen Renderer-Subset).
# Optionen: 1a, 1b, 2a, 2b, 2u, 3a, 3b, 3u.
# VERAPDF_FLAVOUR=2b

# Validation komplett abschalten (z.B. CI ohne Java/veraPDF). 1 = aus.
# VERAPDF_DISABLED=0

