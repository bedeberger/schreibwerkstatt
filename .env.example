# ── Hinweis ──────────────────────────────────────────────────────────────────
# Fast alle Konfigurations-Werte (KI-Provider, Google-OAuth,
# SMTP, Modell-Limits, Cron, veraPDF-Flavour, …) leben jetzt in den
# App-Einstellungen (DB-Tabelle app_settings, Admin-Konsole im Browser).
# Diese Datei deckt nur noch echte Boot-Zeit-ENV-Vars ab — Pfade, Secrets,
# Dev-Helper. Setup läuft über /setup beim ersten Start.
#
# Legacy: liegt ein bekannter alter Key in der ENV (z.B. ANTHROPIC_API_KEY,
# MODEL_TOKEN, GOOGLE_CLIENT_ID, APP_URL, …), wird er beim Server-Start
# einmalig in app_settings gespiegelt (ENV_MAP in lib/app-settings.js).
# Danach ist die DB Wahrheit; ENV-Wert kann entfernt werden.

# ── Pflicht ──────────────────────────────────────────────────────────────────
# Zufälliger Schlüssel für Session-Signierung und Token-Verschlüsselung
# (min. 32 Zeichen). Generieren:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Pfade / Port ─────────────────────────────────────────────────────────────
# Datenbankpfad. Standard: ./schreibwerkstatt.db.
# DB_PATH=/app/data/schreibwerkstatt.db

# Port des Dev-Servers. Standard: 3737.
# PORT=3737

# ── Admin-Login (ENV-Pfad, ohne Google) ──────────────────────────────────────
# Bootstrap-Admin via E-Mail + Passwort. Wahrheit lebt in der ENV:
# - Beim Server-Start spiegelt ensureAdminFromEnv() die ADMIN_EMAIL in
#   app_users mit global_role='admin' (idempotent, ENV-Wechsel-tauglich,
#   kein Restart-Zwang). Passwort wird NIE in die DB geschrieben.
# - Login-Pfad: POST /auth/admin-login (timingSafeEqual gegen ADMIN_PASSWORD,
#   Rate-Limit pro IP). Admin-Form auf /login erscheint nur, wenn
#   ADMIN_PASSWORD gesetzt ist.
# - Andere User loggen sich via Google OIDC ein (Client-ID/Secret in der
#   Admin-Konsole konfigurieren).
# Beides leer lassen → Admin-Login deaktiviert (nur Google-Pfad aktiv).
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=

# ── Lokale Entwicklung ──────────────────────────────────────────────────────
# LOCAL_DEV_MODE=true überspringt Google OAuth komplett und legt automatisch
# eine Dev-Session an (dev@local). NIEMALS in Produktion setzen!
# LOCAL_DEV_MODE=true

# Devmode-Seed (Testbuch beim ersten Start in leerer DB). Default an.
# LOCAL_DEV_SEED=false schaltet den Seed ab.
# LOCAL_DEV_SEED=false

# ── Logging ─────────────────────────────────────────────────────────────────
# Winston-Log-Level. Optionen: error, warn, info (Default), debug.
# LOG_LEVEL=info

# ── Zeitzone ────────────────────────────────────────────────────────────────
# Globale Timezone für Date/Intl + Cron + Tagesaggregate (Heatmap, page_stats).
# Auf UTC-LXC ohne TZ driften Tagesgrenzen → Heute-Ring zeigt falschen Tag.
# Standard: Europe/Zurich.
# TZ=Europe/Zurich

# ── DB-Backup (täglich via systemd-Timer + Pre-Deploy) ──────────────────────
# Konfig für deploy/backup.sh. Timer-Unit lädt /opt/schreibwerkstatt/.env.
# Backup-Pfad (gzip-Snapshots schreibwerkstatt-YYYYmmdd-HHMMSS.db.gz).
# BACKUP_DIR=/opt/schreibwerkstatt/backup
# Aufbewahrung in Tagen (mtime-basiert).
# BACKUP_RETENTION_DAYS=30
# DB-Quelldatei.
# BACKUP_DB_FILE=/opt/schreibwerkstatt/schreibwerkstatt.db

# ── PDF/A-Validierung (veraPDF) ──────────────────────────────────────────────
# Pfad zur veraPDF-CLI-Binary. Standard: 'verapdf' (muss im PATH sein).
# Fehlt das Binary → Validation wird übersprungen, PDF wird trotzdem geliefert.
# Flavour + Disable-Schalter leben in app_settings (Admin-Konsole).
# VERAPDF_BIN=verapdf
