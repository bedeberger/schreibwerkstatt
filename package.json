{
  "name": "schreibwerkstatt",
  "version": "1.0.0",
  "description": "Schreibwerkstatt — Schreiben, Lektorat und Buchanalyse mit KI",
  "license": "AGPL-3.0-or-later",
  "main": "server.js",
  "engines": {
    "node": ">=20 <26"
  },
  "scripts": {
    "prestart": "node scripts/sync-version.js",
    "start": "node server.js",
    "version:sync": "node scripts/sync-version.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:smoke",
    "test:unit": "node --test --test-concurrency=4 \"tests/unit/*.test.js\" \"tests/unit/*.test.mjs\"",
    "test:integration": "node --test \"tests/integration/*.test.js\"",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --config=playwright.app.config.js",
    "cache:cleanup": "node scripts/cache-cleanup.js",
    "squash:regen": "node tools/regen-squashed.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "dependencies": {
    "@turbodocx/html-to-docx": "^1.20.1",
    "altcha-lib": "^2.2.0",
    "better-sqlite3": "^11.0.0",
    "better-sqlite3-session-store": "^0.1.0",
    "compression": "^1.8.1",
    "diff": "^9.0.0",
    "dotenv": "^17.3.1",
    "epub-gen-memory": "^1.1.2",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.0",
    "hyphenation.de": "^0.2.1",
    "hyphenation.en-us": "^0.2.1",
    "hypher": "^0.2.5",
    "jsonrepair": "^3.13.3",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "openid-client": "^5.7.1",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "unpdf": "^1.6.2",
    "winston": "^3.19.0",
    "word-extractor": "^1.0.4",
    "xmlbuilder2": "^4.0.3"
  }
}
