{
  "name": "schreibwerkstatt",
  "version": "1.0.0",
  "description": "Schreibwerkstatt — Schreiben, Lektorat und Buchanalyse mit KI auf BookStack-Basis",
  "license": "AGPL-3.0-or-later",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "node --test --test-concurrency=4 \"tests/unit/*.test.js\" \"tests/unit/*.test.mjs\"",
    "test:integration": "node --test \"tests/integration/*.test.js\"",
    "test:e2e": "playwright test",
    "cache:cleanup": "node scripts/cache-cleanup.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "dependencies": {
    "@turbodocx/html-to-docx": "^1.20.1",
    "better-sqlite3": "^11.0.0",
    "better-sqlite3-session-store": "^0.1.0",
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "epub-gen-memory": "^1.1.2",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.0",
    "jsonrepair": "^3.13.3",
    "linkedom": "^0.18.12",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "openid-client": "^5.7.1",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "xmlbuilder2": "^4.0.3"
  }
}
